# ─────────────────────────────────────────────────────────────────────────────
# jrs-platform — environment variables
#
# Copy to .env and fill in real values.
# NEVER commit .env to git.
#
# AWS: inject these via ECS task definition environment overrides,
#      sourcing from AWS Secrets Manager / SSM Parameter Store.
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
# Must be identical in both jrs-auth-service and jrs-api-gateway.
JRS_JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# ── Redis ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 16
REDIS_PASSWORD=REPLACE_WITH_RANDOM_PASSWORD

# ── Auth Service DB ────────────────────────────────────────────────────────
AUTH_DB_URL=jdbc:postgresql://your-rds-host:5432/jrs_auth
AUTH_DB_USER=jrs_auth_user
AUTH_DB_PASSWORD=REPLACE_WITH_DB_PASSWORD

# ── Rate Limiting (optional overrides — defaults shown) ───────────────────
RATE_LIMIT_ANON=10
RATE_LIMIT_ANON_BURST=20
RATE_LIMIT_AUTH=100
RATE_LIMIT_AUTH_BURST=200

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ────────────────────────────────────────────────────────────────
# Values: TRACE DEBUG INFO WARN ERROR
LOG_LEVEL=INFO

# ── Build metadata (set by CI, not manually) ──────────────────────────────
BUILD_VERSION=local
GIT_SHA=unknown
