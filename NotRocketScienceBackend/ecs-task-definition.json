{
  "family": "jrs-api-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/jrs-ecs-execution-role",
  "taskRoleArn":      "arn:aws:iam::ACCOUNT_ID:role/jrs-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "jrs-api-gateway",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/jrs-api-gateway:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],

      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE",          "value": "docker" },
        { "name": "SERVER_PORT",                      "value": "8080" },
        { "name": "JRS_JWT_ISSUER",                   "value": "jrs-auth-service" },
        { "name": "JRS_JWT_AUDIENCE",                 "value": "jrs-api-gateway" },
        { "name": "JRS_JWT_CLOCK_SKEW_SECONDS",       "value": "30" },
        { "name": "JRS_CIRCUIT_BREAKER_FAILURE_RATE_THRESHOLD", "value": "50" },
        { "name": "JRS_CIRCUIT_BREAKER_SLIDING_WINDOW_SIZE",    "value": "10" },
        { "name": "JRS_CIRCUIT_BREAKER_WAIT_DURATION_IN_OPEN_STATE", "value": "30s" },
        { "name": "RATE_LIMIT_ANON",                  "value": "10" },
        { "name": "RATE_LIMIT_ANON_BURST",            "value": "20" },
        { "name": "RATE_LIMIT_AUTH",                  "value": "100" },
        { "name": "RATE_LIMIT_AUTH_BURST",            "value": "200" },
        { "name": "LOGGING_LEVEL_COM_JRS_GATEWAY",    "value": "INFO" }
      ],

      "secrets": [
        {
          "name": "JRS_JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:jrs/jwt-secret"
        },
        {
          "name": "SPRING_DATA_REDIS_HOST",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/jrs/redis/host"
        },
        {
          "name": "SPRING_DATA_REDIS_PORT",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/jrs/redis/port"
        },
        {
          "name": "SPRING_DATA_REDIS_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:jrs/redis-password"
        },
        {
          "name": "JRS_ROUTES_AUTH_URI",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/jrs/routes/auth-uri"
        },
        {
          "name": "JRS_ROUTES_ROCKET_URI",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/jrs/routes/rocket-uri"
        },
        {
          "name": "JRS_ROUTES_LAUNCH_URI",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/jrs/routes/launch-uri"
        },
        {
          "name": "JRS_CORS_ALLOWED_ORIGINS",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/jrs/cors/allowed-origins"
        }
      ],

      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -qO- http://localhost:8080/actuator/health/liveness | grep -q UP || exit 1"
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/jrs-api-gateway",
          "awslogs-region":        "REGION",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group":  "true"
        }
      },

      "stopTimeout": 30,

      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 65536,
          "hardLimit": 65536
        }
      ]
    }
  ]
}
