<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.justrocketscience</groupId>
        <artifactId>just-rocket-science</artifactId>
        <version>0.0.1-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>jrs-auth-service</artifactId>
    <packaging>jar</packaging>
    <name>JRS Auth Service</name>
    <description>
        JWT authentication microservice.
        Handles register, login, logout, token refresh.
        Owns the users + refresh_tokens schema.
    </description>

    <dependencies>

        <!-- ════════════════════════════════════════
             SPRING BOOT STARTERS
        ════════════════════════════════════════ -->

        <!-- Core MVC: DispatcherServlet, REST controllers,
             embedded Tomcat server -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!-- Security filter chain, BCryptPasswordEncoder,
             UserDetailsService, SecurityContext -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>

        <!-- Hibernate ORM + Spring Data repositories
             + JPA transaction management -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
        </dependency>

        <!-- Spring Data Redis + Lettuce client (default).
             Used for: JWT JTI blacklist, token TTL store -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-redis</artifactId>
        </dependency>

        <!-- Jakarta Bean Validation (@NotBlank, @Email, @Size)
             + Hibernate Validator (RI) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!-- Actuator: /actuator/health, /metrics, /prometheus
             Health indicators for DB, Redis auto-configured -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>

        <!-- AOP support: @Aspect for logging, timing,
             audit trail cross-cutting concerns -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-aop</artifactId>
        </dependency>

        <!-- ════════════════════════════════════════
             DATABASE
        ════════════════════════════════════════ -->

        <!-- PostgreSQL JDBC driver.
             runtime scope = not needed at compile time,
             only when the app actually runs -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- Flyway core: manages DB schema versioning.
             Runs migrations from resources/db/migration/
             on startup before any JPA operations -->
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-core</artifactId>
        </dependency>

        <!-- Flyway PostgreSQL support: needed separately
             since Flyway 10.x split DB-specific support
             into separate artifacts -->
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-database-postgresql</artifactId>
        </dependency>

        <!-- ════════════════════════════════════════
             JWT
        ════════════════════════════════════════ -->

        <!-- JJWT API: interfaces for Jwts.builder(),
             Claims, JwtParser. Compile-time dependency -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-api</artifactId>
        </dependency>

        <!-- JJWT implementation: actual HS256/RS256 signing.
             runtime only — never reference impl classes directly -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-impl</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- JJWT Jackson integration: serializes/deserializes
             JWT claims to/from JSON using ObjectMapper.
             runtime only -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-jackson</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- ════════════════════════════════════════
             OBSERVABILITY
        ════════════════════════════════════════ -->

        <!-- Micrometer Tracing bridge for Brave (Zipkin's
             instrumentation library). Enables automatic
             span creation on HTTP requests, DB calls -->
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-tracing-bridge-brave</artifactId>
        </dependency>

        <!-- Zipkin reporter: sends completed spans to
             Zipkin server over HTTP. Async, non-blocking -->
        <dependency>
            <groupId>io.zipkin.reporter2</groupId>
            <artifactId>zipkin-reporter-brave</artifactId>
        </dependency>

        <!-- Prometheus metrics exporter.
             Exposes /actuator/prometheus for Grafana scraping.
             runtime — Prometheus pulls, we just expose -->
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-registry-prometheus</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- ════════════════════════════════════════
             MAPPING
        ════════════════════════════════════════ -->

        <!-- MapStruct: compile-time DTO ↔ Entity mapper.
             Generates UserMapperImpl.java at build time.
             Zero reflection — faster than ModelMapper -->
        <dependency>
            <groupId>org.mapstruct</groupId>
            <artifactId>mapstruct</artifactId>
        </dependency>

        <!-- ════════════════════════════════════════
             INTERNAL MODULES
        ════════════════════════════════════════ -->

        <!-- Our own shared library: ApiResponse envelope,
             error codes, custom exceptions -->
        <dependency>
            <groupId>com.justrocketscience</groupId>
            <artifactId>jrs-common</artifactId>
        </dependency>

        <!-- ════════════════════════════════════════
             TEST DEPENDENCIES
        ════════════════════════════════════════ -->

        <!-- JUnit 5 + Mockito + AssertJ + MockMvc.
             Includes @SpringBootTest, @WebMvcTest,
             @DataJpaTest slice test support -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Spring Security test utilities:
             @WithMockUser, SecurityMockMvcRequestPostProcessors,
             mockMvc.with(csrf()) -->
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Testcontainers core: manages Docker containers
             in JUnit 5 lifecycle via @Container annotation -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Testcontainers JUnit 5 integration:
             @Testcontainers class annotation +
             @Container field management -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Testcontainers PostgreSQL module:
             PostgreSQLContainer — starts real Postgres
             in Docker for integration tests -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>postgresql</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Testcontainers Redis: starts real Redis
             for TokenBlacklistService integration tests -->
        <!-- Note: no official redis module from Testcontainers;
             use GenericContainer with "redis:7-alpine" image -->
        <dependency>
            <groupId>com.redis</groupId>
            <artifactId>testcontainers-redis</artifactId>
            <version>2.2.2</version>
            <scope>test</scope>
        </dependency>

        <!-- H2 in-memory DB for @DataJpaTest slices.
             Faster than Testcontainers for pure JPA tests.
             @DataJpaTest auto-configures H2 by default -->
        <dependency>
            <groupId>com.h2database</groupId>
            <artifactId>h2</artifactId>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <build>
        <plugins>

            <!-- Spring Boot Maven Plugin: packages the
                 executable fat-jar for deployment/Docker -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>

            <!-- Compiler: handles Lombok + MapStruct
                 annotation processing (inherited from root,
                 re-activated explicitly) -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
            </plugin>

        </plugins>
    </build>

</project>
