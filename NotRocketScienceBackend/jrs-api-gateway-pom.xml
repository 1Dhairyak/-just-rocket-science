<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.justrocketscience</groupId>
        <artifactId>just-rocket-science</artifactId>
        <version>0.0.1-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>jrs-api-gateway</artifactId>
    <packaging>jar</packaging>
    <name>JRS API Gateway</name>
    <description>
        Spring Cloud Gateway (reactive/WebFlux).
        Handles: routing, JWT validation, rate limiting,
        correlation IDs, CORS, circuit breakers.
        IMPORTANT: Uses WebFlux — spring-boot-starter-web
        must NOT be on the classpath.
    </description>

    <dependencies>

        <!-- ════════════════════════════════════════
             CORE GATEWAY
             !! CRITICAL !!
             spring-cloud-starter-gateway pulls in
             spring-boot-starter-webflux automatically.
             NEVER add spring-boot-starter-web here —
             it causes "cannot have both web and webflux"
             startup exception.
        ════════════════════════════════════════ -->
        <dependency>
            <groupId>org.springframework.cloud</groupId>
            <artifactId>spring-cloud-starter-gateway</artifactId>
        </dependency>

        <!-- ════════════════════════════════════════
             REDIS (REACTIVE)
             Must use reactive Redis — NOT the blocking
             spring-boot-starter-data-redis.
             Used for: Redis-backed rate limiter
             (RequestRateLimiter GatewayFilter).
             Lettuce client is reactive by default.
        ════════════════════════════════════════ -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-redis-reactive</artifactId>
        </dependency>

        <!-- ════════════════════════════════════════
             CIRCUIT BREAKER (REACTIVE)
             Resilience4j reactive variant for WebFlux.
             Powers: CircuitBreaker GatewayFilter on routes.
             When downstream service is down, triggers
             fallback endpoint instead of propagating error.
        ════════════════════════════════════════ -->
        <dependency>
            <groupId>org.springframework.cloud</groupId>
            <artifactId>spring-cloud-starter-circuitbreaker-reactor-resilience4j</artifactId>
        </dependency>

        <!-- ════════════════════════════════════════
             JWT VALIDATION
             Gateway validates token signature + expiry
             without calling auth-service (stateless check).
             JTI blacklist check still hits Redis.
             Same three jjwt jars as auth-service.
        ════════════════════════════════════════ -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-api</artifactId>
        </dependency>
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-impl</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-jackson</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- ════════════════════════════════════════
             ACTUATOR
             Health probes for K8s readiness/liveness.
             /actuator/health → ALB target group checks.
        ════════════════════════════════════════ -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>

        <!-- ════════════════════════════════════════
             OBSERVABILITY
             Same tracing stack as auth-service.
             Gateway creates the ROOT span for every
             request — all downstream spans are children.
             This is the most important service to instrument.
        ════════════════════════════════════════ -->
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-tracing-bridge-brave</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zipkin.reporter2</groupId>
            <artifactId>zipkin-reporter-brave</artifactId>
        </dependency>
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-registry-prometheus</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- ════════════════════════════════════════
             INTERNAL MODULES
             Common envelope for fallback responses.
             Gateway returns ApiResponse on circuit open.
        ════════════════════════════════════════ -->
        <dependency>
            <groupId>com.justrocketscience</groupId>
            <artifactId>jrs-common</artifactId>
        </dependency>

        <!-- Lombok: @Slf4j on filters, @Value on config -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- ════════════════════════════════════════
             TEST
        ════════════════════════════════════════ -->

        <!-- WebFlux test utilities: WebTestClient for
             reactive endpoint testing (replaces MockMvc) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Reactor test: StepVerifier for testing
             Mono<> / Flux<> chains in filter logic -->
        <dependency>
            <groupId>io.projectreactor</groupId>
            <artifactId>reactor-test</artifactId>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
            </plugin>
        </plugins>
    </build>

</project>
